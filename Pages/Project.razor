@page "/projects"
@page "/projet"
@using FrontEndPortefolio.Components

<PageTitle>Mes projets</PageTitle>

<NavigationBar />

<main class="projects-page" aria-label="Page Mes projets">
	<section class="projects-toolbar-section" aria-label="Recherche et filtres">
		<div class="projects-toolbar-shell">
			<div class="projects-toolbar">
				<div class="search-box">
					<input
						type="search"
						class="projects-search-input"
						placeholder="Rechercher un projet..." />
				</div>

				<button type="button" class="filters-open-btn" @onclick="OpenFilterPopup">
					Filtres
				</button>
			</div>
		</div>
	</section>

	<section class="projects-list-section" aria-label="Liste des projets">
		<div class="projects-grid-shell">
			<div class="projects-grid">
				@foreach (var project in projects)
				{
					<ProjectCard
						Title="@project.Title"
						ImageUrl="@project.ImageUrl"
						Language="@project.Language"
						Framework="@project.Framework"
						ApplicationType="@project.ApplicationType"
						Date="@project.Date"
						Href="@project.Href" />
				}
			</div>
		</div>
	</section>
</main>

<PopUpFiltres
	IsOpen="isFilterPopupOpen"
	OnClose="CloseFilterPopup" />

<Footer />

